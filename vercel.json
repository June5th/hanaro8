{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/social-preview\\.png", "dest": "/social-preview.png" },
    { "src": "/social-preview\\.svg", "dest": "/social-preview.svg" },
    { "src": "/", "dest": "/index.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}

